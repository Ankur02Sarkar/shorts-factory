# ─────────────────────────────────────────────────────────────
#  Shorts Factory — configuration template
#  Copy to `.env` (or wire the equivalent files, see SETUP.md) and fill in.
#  NEVER commit the filled-in version. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────

# ── YouTube (via Postiz) ─────────────────────────────────────
# In this project these come from the Postiz Docker container env + Postgres.
# If you run standalone, set them here instead and adapt the scripts.
YOUTUBE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-google-oauth-client-secret
# The long-lived refresh token with the youtube.upload scope (kept in Postiz's DB by default):
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# ── GCP project (for the YouTube Analytics API) ──────────────
GCP_PROJECT_NUMBER=your-gcp-project-number

# ── Postiz (self-hosted) ─────────────────────────────────────
POSTIZ_BASE_URL=http://localhost:4007/api
# Get from Postiz UI → Settings → Developers → Access. Also readable from ~/.config/postiz/key
POSTIZ_API_KEY=your-postiz-org-api-key

# ── Gmail notifications (digest + failure alerts) ────────────
# Create at https://myaccount.google.com/apppasswords  (needs 2-Step Verification).
# Stored by the app at ~/.config/shorts/email.json (mode 600) — do not paste real values into git.
NOTIFY_EMAIL_ADDRESS=you@gmail.com
NOTIFY_EMAIL_APP_PASSWORD=abcd efgh ijkl mnop
